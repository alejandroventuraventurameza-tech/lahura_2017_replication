/files/
/ree-33-lahura.pdf
/ree-13-01.pdf
/moneda-170-01.pdf
/hefferman1997.pdf
/sander2004.pdf
/EBSCO-FullText-*.pdf

# Enunciado del examen final: no debe quedar público por si el profesor
# lo reutiliza en otro semestre; se conserva solo en la copia local.
/ef_metriamacro.pdf

# Manuales de EViews (material de terceros, ~42 MB, no es contenido del proyecto)
/EViews*.pdf

# --- Material de verificación histórica (voluminoso, no esencial para
#     reproducir los resultados principales; ya documentado en el Anexo) ---
/nota_semanal/
/data/historico_bcrp/

# --- Material fuente original de la Pregunta 2: ya fusionado con el
#     código y documento propios (Anexo A.10, Sección 2.3 y 2.4 del
